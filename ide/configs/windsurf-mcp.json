{
  "mcpServers": {
    "superlocalmemory": {
      "command": "python3",
      "args": [
        "-m", "superlocalmemory.mcp.server"
      ],
      "cwd": "{{INSTALL_DIR}}",
      "env": {
        "PYTHONPATH": "{{INSTALL_DIR}}"
      },
      "transport": "stdio",
      "description": "SuperLocalMemory V3 - 100% local memory system for AI assistants"
    }
  }
}
