{
  "mcpServers": {
    "superlocalmemory": {
      "command": "python3",
      "args": ["-m", "superlocalmemory.mcp.server"],
      "env": {
        "PYTHONPATH": "{{INSTALL_DIR}}"
      },
      "cwd": "{{INSTALL_DIR}}",
      "description": "SuperLocalMemory V3 - 100% local memory system"
    }
  }
}
